  "initialization_sequence": [
    "1. run.py → run_bootstrap.py run_gui()",
    "2. SQMInventoryAppFull() instantiated",
    "3. _init_state() — theme preference loaded",
    "4. _show_loading_splash() — splash screen displayed",
    "5. _init_engine() — database engine initialized",
    "6. _setup_ui() — window structure created",
    "7. _setup_menu() — menu bar setup",
    "8. _setup_toolbar() — toolbar with action buttons",
    "9. _setup_main_frame() — sidebar + notebook layout",
    "10. _setup_status_bar() — status bar setup",
    "11. _setup_*_tab() — individual tab initialization (9 tabs)",
    "12. _load_window_config() — geometry restore (150ms delay)",
    "13. root.deiconify() — window displayed",
    "14. _refresh_dashboard() → root.mainloop()"
  ],
