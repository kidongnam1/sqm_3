        },
        {
          "name": "statusbar_frame",
          "type": "ttk.Frame",
          "layout": "pack(fill=x, side=bottom)",
          "children": [
            {"name": "mode_label", "description": "READ/WRITE indicator"},
            {"name": "module_status_label", "description": "Module status (Modules: X/Y)"},
            {"name": "status_label", "description": "Current status message"},
            {"name": "_inv_summary_label", "description": "Inventory summary (LOT count, Tonbag, Stock weight)"},
            {"name": "progress_bar", "description": "Progress indicator"}
          ]
        }
